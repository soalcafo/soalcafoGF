# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# ─── Database (Supabase Postgres) ─────────────────────────────────────────
# From Supabase: Project Settings → Database → Connection string.
#
# DATABASE_URL  = the TRANSACTION POOLER url (port 6543). Used by the app at runtime.
#                 IMPORTANT: keep the ?pgbouncer=true&connection_limit=1 suffix —
#                 it tells Prisma it is talking to a transaction-mode pooler.
# DIRECT_URL    = the SESSION / DIRECT url (port 5432). Used by Prisma Migrate only.
#
# Use an EU region project (e.g. Frankfurt) for GDPR data residency.
DATABASE_URL="postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────
# Generate a secret with:  npx auth secret    (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# Base url of the app. In local dev this is fine as-is.
AUTH_URL="http://localhost:3000"
# Trust the host header (needed on Vercel/preview deployments).
AUTH_TRUST_HOST="true"

# ─── Email (magic-link login + invitations) ───────────────────────────────
# Using Resend (https://resend.com). EU region recommended for GDPR.
# Phase 0 works without this (credentials login only); fill it in for magic-link.
AUTH_RESEND_KEY=""
EMAIL_FROM="no-reply@your-domain.example"

# ─── App config ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Training Hub"
# Default locale for new users / unauthenticated visitors.
NEXT_PUBLIC_DEFAULT_LOCALE="pt-PT"

# ─── Object storage (certificates / attachments) — NOT needed until Phase 1b ─
# Supabase Storage is S3-compatible; fill these in when we reach certificates.
# STORAGE_ENDPOINT=""
# STORAGE_BUCKET=""
# STORAGE_ACCESS_KEY_ID=""
# STORAGE_SECRET_ACCESS_KEY=""
